<%# locals: (months_in_arrears_principal:, months_in_arrears_admin:) %>
<%# Renders nothing when warehouse data is not yet available (both nil). %>
<% unless months_in_arrears_principal.nil? && months_in_arrears_admin.nil? %>
<%
  principal  = months_in_arrears_principal.to_i
  admin      = months_in_arrears_admin.to_i
  in_arrears = principal > 0 || admin > 0
%>
<% if in_arrears %>
  <div class="rounded-xl border border-red-200 bg-red-tint-5 p-4 flex gap-3 items-start">
    <div class="w-8 h-8 rounded-lg bg-red-tint-10 flex items-center justify-center shrink-0 mt-0.5">
      <%= icon("alert-triangle", color: :destructive, size: "sm") %>
    </div>
    <div class="flex-1 min-w-0">
      <p class="font-semibold text-destructive text-sm mb-1"><%= t("insights.arrears.title_in_arrears") %></p>
      <% if principal > 0 %>
        <p class="text-xs text-secondary">
          <%= t("insights.arrears.principal_months", count: principal) %>
        </p>
      <% end %>
      <% if admin > 0 %>
        <p class="text-xs text-secondary">
          <%= t("insights.arrears.admin_months", count: admin) %>
        </p>
      <% end %>
      <p class="text-xs text-secondary mt-2"><%= t("insights.arrears.contact_prompt") %></p>
    </div>
  </div>
<% else %>
  <div class="rounded-xl border border-green-200 bg-green-tint-5 p-4 flex gap-3 items-center">
    <div class="w-8 h-8 rounded-lg bg-green-tint-10 flex items-center justify-center shrink-0">
      <%= icon("check-circle", color: :success, size: "sm") %>
    </div>
    <p class="font-semibold text-success text-sm"><%= t("insights.arrears.good_standing") %></p>
  </div>
<% end %>
<% end %>

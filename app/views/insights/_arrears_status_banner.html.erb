<%# locals: (months_in_arrears_principal:, months_in_arrears_admin:) %>
<%# Renders nothing when warehouse data is not yet available (both nil). %>
<% unless months_in_arrears_principal.nil? && months_in_arrears_admin.nil? %>
<%
  principal  = months_in_arrears_principal.to_i
  admin      = months_in_arrears_admin.to_i
  in_arrears = principal > 0 || admin > 0
%>
<% if in_arrears %>
  <%= render DS::Alert.new(variant: :destructive, title: t("insights.arrears.title_in_arrears")) do %>
    <% if principal > 0 %>
      <p><%= t("insights.arrears.principal_months", count: principal) %></p>
    <% end %>
    <% if admin > 0 %>
      <p><%= t("insights.arrears.admin_months", count: admin) %></p>
    <% end %>
    <p class="mt-1"><%= t("insights.arrears.contact_prompt") %></p>
  <% end %>
<% else %>
  <%= render DS::Alert.new(variant: :success, message: t("insights.arrears.good_standing")) %>
<% end %>
<% end %>

<%# locals: (loan_account:, instalment_due_date:, monthly_instalment:, recent_transactions:) %>
<%
  if loan_account && instalment_due_date
    overdue      = instalment_due_date < Date.today
    paid_this_month = recent_transactions&.any? { |e| e.date >= Date.today.beginning_of_month }
    up_to_date   = !overdue || paid_this_month
  end
%>
<div class="rounded-xl bg-container border border-primary p-5 shadow-border-xs">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= render DS::FilledIcon.new(icon: "banknote", hex_color: "#84BD00", size: "lg") %>
      <span class="font-bold text-primary"><%= t("insights.next_instalment.title") %></span>
    </div>
    <% if loan_account && instalment_due_date %>
      <% if up_to_date %>
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-green-tint-10 text-success">
          <%= t("insights.next_instalment.up_to_date") %>
        </span>
      <% elsif overdue %>
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-red-tint-10 text-destructive">
          <%= t("insights.next_instalment.overdue") %>
        </span>
      <% end %>
    <% end %>
  </div>

  <% if loan_account && instalment_due_date %>
    <p class="text-xs text-secondary mb-1"><%= t("insights.next_instalment.due_date_label") %></p>
    <p class="text-2xl font-semibold mb-3 privacy-sensitive <%= (overdue && !up_to_date) ? "text-destructive" : "text-primary" %>">
      <%= l(instalment_due_date, format: :long) %>
    </p>
    <% if monthly_instalment %>
      <p class="text-xs text-secondary mb-1"><%= t("insights.next_instalment.amount_label") %></p>
      <p class="text-lg font-bold text-primary privacy-sensitive"><%= monthly_instalment.format %></p>
    <% end %>
  <% else %>
    <% if loan_account && monthly_instalment %>
      <p class="text-xs text-secondary mb-1"><%= t("insights.next_instalment.amount_label") %></p>
      <p class="text-2xl font-semibold text-primary mb-2 privacy-sensitive"><%= monthly_instalment.format %></p>
      <p class="text-xs text-secondary"><%= t("insights.next_instalment.due_date_unavailable") %></p>
    <% else %>
      <p class="text-2xl font-semibold text-primary">
        <em class="font-normal text-base not-italic text-secondary"><%= t("insights.coming_soon") %></em>
      </p>
    <% end %>
  <% end %>
</div>

<%= link_to chats_path, class: "block rounded-xl border border-[#986EF9] bg-container p-4 shadow-border-xs transition-opacity hover:opacity-90" do %>
  <div class="flex items-center gap-4">
    <%= render DS::FilledIcon.new(icon: "message-circle", hex_color: "#986EF9", size: "lg", rounded: true) %>
    <div class="flex-1 min-w-0">
      <p class="font-bold text-[#986EF9]"><%= t("insights.ask_anything.title") %></p>
      <p class="text-sm text-secondary"><%= t("insights.ask_anything.subtitle") %></p>
    </div>
    <%= icon("chevron-right", class: "text-secondary shrink-0", size: "sm") %>
  </div>
<% end %>

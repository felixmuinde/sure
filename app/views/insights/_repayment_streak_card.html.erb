<%# locals: (loan_account:, repayment_streak:) %>
<%
  streak        = repayment_streak.to_i
  has_streak    = loan_account && streak > 0
  streak_color  = has_streak ? "text-orange-500" : "text-secondary"
%>
<div class="rounded-xl bg-container border border-primary p-5 shadow-border-xs">
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 min-w-0">
      <%= render DS::FilledIcon.new(icon: "flame", hex_color: has_streak ? "#f97316" : nil, size: "lg") %>
      <div class="min-w-0">
        <p class="font-bold text-primary"><%= t("insights.repayment_streak.title") %></p>
        <p class="text-xs text-secondary"><%= t("insights.repayment_streak.subtitle") %></p>
      </div>
    </div>

    <% if loan_account %>
      <div class="text-right shrink-0">
        <p class="text-3xl font-semibold <%= streak_color %> privacy-sensitive"><%= streak %></p>
        <p class="text-xs font-semibold <%= streak_color %>"><%= t("insights.repayment_streak.months", count: streak) %></p>
      </div>
    <% else %>
      <em class="text-sm text-secondary not-italic shrink-0"><%= t("insights.coming_soon") %></em>
    <% end %>
  </div>
</div>
